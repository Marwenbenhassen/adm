dia.mansour@gmail.com', 200.00, 'Support aux événements', 'VALIDE', NOW(), NOW()),\000d\000a('Anonyme', 'anonyme@mellita.tn', 50.00, NULL, 'EN_ATTENTE', NOW(), NOW());\000d\000a\000d\000a-- -----------------------------------------------------\000d\000a-- 11. DOCUMENTS\000d\000a-- -----------------------------------------------------\000d\000aINSERT INTO documents (titre, description, type, categorie, url, taille, statut, uploaded_by, created_at) VALUES\000d\000a('Règlement Intérieur', 'Règlement intérieur de l[*]\\'association', 'PDF', 'REGLEMENT', '/documents/reglement.pdf', 1024000, 'PUBLIQUE', 1, NOW()),\000d\000a('Brochure Clubs', 'Brochure présentant tous les clubs', 'PDF', 'PUBLICITE', '/documents/brochure-clubs.pdf', 2048000, 'PUBLIQUE', 1, NOW()),\000d\000a('Formulaire Adhésion', 'Formulaire d\\'adhésion 2025', 'DOCX', 'ADMINISTRATIF', '/documents/formulaire-adhesion.docx', 512000, 'PRIVEE', 1, NOW()),\000d\000a('Planning Formations', 'Planning des formations 2025', 'XLSX', 'FORMATION', '/documents/planning-formations.xlsx', 768000, 'MEMBRE', 1, NOW()),\000d\000a('Guide du Parent', 'Guide pour les parents', 'PDF', 'GUIDE', '/documents/guide-parent.pdf', 1536000, 'PUBLIQUE', 1, NOW());\000d\000a\000d\000a-- -----------------------------------------------------\000d\000a-- 12. ACTUALITÉS\000d\000a-- -----------------------------------------------------\000d\000aINSERT INTO actualites (titre, titre_ar, contenu, contenu_ar, image, statut, publie_le, created_by, created_at) VALUES\000d\000a('Nouveaux Clubs Ouverts', 'أندية جديدة مفتوحة', 'Nous avons le plaisir d\\'annoncer l\\'ouverture de deux nouveaux clubs : Sfax Lions et La Marsa Tennis', 'يسرنا أن نعلن عن افتتاح ناديين جديدين: أسود صفاقس وتنس المرسى', 'new-clubs.jpg', 'PUBLIEE', NOW(), 1, NOW()),\000d\000a('Formation Web Development', 'تطوير الويب', 'Inscription ouverte pour la formation Web Development', 'التسجيل مفتوح لتكوين تطوير الويب', 'web-course.jpg', 'PUBLIEE', NOW(), 1, NOW()),\000d\000a('Gala Annu