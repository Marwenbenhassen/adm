  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd mellita-frontend && npm run build",
  "outputDirectory": "mellita-frontend/dist/mellita-frontend/browser",
  "installCommand": "cd mellita-frontend && npm install",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}

